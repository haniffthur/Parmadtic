# ==========================================
# KONFIGURASI ENVIRONMENT PARMADTIC
# ==========================================

# Ubah menjadi False saat deploy ke Production
DEBUG=True

# Secret Key Django (Isi dengan string acak yang panjang saat di-deploy)
SECRET_KEY=django-insecure-ganti-dengan-key-rahasia-anda-disini

# Host yang diizinkan (Gunakan * untuk local, atau masukkan domain saat live)
ALLOWED_HOSTS=*

# URL Database (Biarkan kosong jika menggunakan SQLite bawaan)
# DATABASE_URL=postgres://user:password@localhost:5432/parmadtic

# Konfigurasi Redis untuk WebSocket (Opsional jika pakai InMemory di lokal)
# REDIS_URL=redis://127.0.0.1:6379/1